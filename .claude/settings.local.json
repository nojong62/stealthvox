{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git config *)",
      "Bash(flutter pub *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell([System.Environment]::GetEnvironmentVariable\\(\"PATH\", \"User\"\\) -split ';' | Where-Object { $_ -ne '' })",
      "PowerShell([System.Environment]::GetEnvironmentVariable\\(\"PATH\", \"Machine\"\\) -split ';' | Where-Object { $_ -ne '' })"
    ]
  }
}
